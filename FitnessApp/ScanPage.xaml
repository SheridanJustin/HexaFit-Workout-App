<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitnessApp.ViewModels"
             xmlns:local="clr-namespace:FitnessApp"
             x:Class="FitnessApp.ScanPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False"
             Padding="0,0,0,0" 
             >

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <local:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />

            <!-- Gradient background brush -->
            <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2C2C2C" Offset="0.0" />
                <GradientStop Color="#1A1A1A" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="20" RowDefinitions="*,Auto" IgnoreSafeArea="True" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        <!-- App Title -->
        <Label Text="🏋️ AI Fitness Scanner"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center"
               Margin="0,20,0,10"/>

        <!-- Main Card -->
        <Frame Grid.Row="0"
               CornerRadius="24"
               HasShadow="True"
               Background="{StaticResource CardGradient}"
               Padding="30"
               Margin="0,10"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand">
            <Grid>
                <!-- Placeholder -->
                <Label Text="{Binding PlaceholderText}"
                       FontSize="18"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#B0B0B0"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"
                       IsVisible="{Binding IsPlaceholderVisible}"/>

                <!-- Result -->
                <StackLayout IsVisible="{Binding Prediction, Converter={StaticResource StringNotEmptyConverter}}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12">
                    <Label Text="{Binding Prediction}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#00E676"
                           HorizontalTextAlignment="Center"/>
                    <BoxView HeightRequest="1" Color="#333333" HorizontalOptions="Fill"/>
                    <Label Text="{Binding Instructions}"
                           FontSize="16"
                           TextColor="#DDDDDD"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           Margin="0,8,0,0"/>
                </StackLayout>

                <!-- Loading Spinner -->
                <StackLayout IsVisible="{Binding IsLoading}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12">
                    <ActivityIndicator IsRunning="True"
                                       Color="#00E5FF"
                                       WidthRequest="40"
                                       HeightRequest="40"/>
                    <Label Text="Analyzing..."
                           FontSize="16"
                           TextColor="#AAAAAA"
                           HorizontalTextAlignment="Center"/>
                </StackLayout>
            </Grid>
        </Frame>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,Auto,*"
              Margin="0,20,0,10"
              ColumnSpacing="20"
              VerticalOptions="End">
            <!-- Camera -->
            <Frame WidthRequest="73"
                   HeightRequest="73"
                   CornerRadius="35"
                   Padding="0"
                   HasShadow="False"
                   BackgroundColor="#1F1F1F"
                   VerticalOptions="Center"
                   HorizontalOptions="Center">
                <ImageButton Source="camera.png"
                             BackgroundColor="Transparent"
                             Aspect="AspectFit"
                             WidthRequest="43"
                             HeightRequest="43"
                             Command="{Binding TakePhotoCommand}"/>
            </Frame>

            <!-- Gallery -->
            <Frame WidthRequest="73"
                   HeightRequest="73"
                   CornerRadius="35"
                   Padding="0"
                   HasShadow="False"
                   BackgroundColor="#1F1F1F"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Grid.Column="1">
                <ImageButton Source="gallery.png"
                             BackgroundColor="Transparent"
                             Aspect="AspectFit"
                             WidthRequest="43"
                             HeightRequest="43"
                             Command="{Binding PickImageCommand}"/>
            </Frame>


            <!-- Submit -->
            <Button Text="Submit"
                    BackgroundColor="#00E676"
                    TextColor="Black"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="30"
                    HeightRequest="60"
                    Grid.Column="2"
                    Command="{Binding PredictCommand}"
                    IsEnabled="{Binding InputText, Converter={StaticResource StringNotEmptyConverter}}"
                    Shadow="{OnPlatform Android={Shadow Brush=#000000, Radius=12, Opacity=0.4}}"/>
        </Grid>
    </Grid>
</ContentPage>
